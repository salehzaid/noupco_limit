# Copy to .env and set your Postgres URL.
# Create DB first: psql -d postgres -c "CREATE DATABASE nupco_limit;"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nupco_limit
# Optional: protect import and admin endpoints. If set, requests must send header X-Admin-Key with this value.
ADMIN_KEY=change-me
# Anthropic API key for AI report generation
ANTHROPIC_API_KEY=your-anthropic-api-key-here
